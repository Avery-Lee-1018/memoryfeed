{
  "name": "memory-feed-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply memory_feed --local",
    "d1:migrate:remote": "wrangler d1 migrations apply memory_feed --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.19",
    "wrangler": "^4.11.1"
  }
}
